# --- Database (PostgreSQL) ---
# Local dev and production both use Postgres. Spin up a free instance (Neon,
# Vercel Postgres, Render Postgres, or local docker) and paste its URL here.
# Example: postgresql://user:password@host:5432/agentcred?sslmode=require
DATABASE_URL=""

# --- Wallet sign-in session ---
# HMAC secret that signs the session cookie set after a wallet proves ownership
# via personal_sign. Generate one with: openssl rand -hex 32
SESSION_SECRET=""

# --- OpenRouter (AI behavioral reports + comparison verdicts) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# Any OpenRouter-hosted model id. Default below is a fast, inexpensive choice.
OPENROUTER_MODEL="anthropic/claude-haiku-4.5"
# Optional attribution headers shown on the OpenRouter dashboard
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_SITE_NAME="AgentCred"
